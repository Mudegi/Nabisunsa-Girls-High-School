{
  "expo": {
    "name": "Nabisunsa Girls' SS",
    "slug": "nabisunsa-girls-hs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpeg",
    "userInterfaceStyle": "light",
    "scheme": "nabisunsa",
    "splash": {
      "image": "./assets/splash-icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nabisunsa.app"
    },
    "android": {
      "package": "com.nabisunsa.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icon.jpeg"
      }
    },
    "web": {
      "favicon": "./assets/favicon.jpeg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e274f660-fd88-4fab-a63e-946e0994c8d3"
      }
    },
    "owner": "kissa-kian"
  }
}
