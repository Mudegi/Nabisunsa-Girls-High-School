rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════
    //  Helper functions
    // ════════════════════════════════════════════

    // Authenticated user's profile document
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return isSignedIn() && userDoc().role == role;
    }

    function isAnyRole(roles) {
      return isSignedIn() && userDoc().role in roles;
    }

    // Does the caller belong to the same school as the resource?
    function sameSchool(schoolId) {
      return isSignedIn() && userDoc().schoolId == schoolId;
    }

    // Is the caller a parent whose childIds array contains a given studentId?
    function isParentOf(studentId) {
      return isRole('parent') && studentId in userDoc().childIds;
    }

    // ════════════════════════════════════════════
    //  /users/{userId}
    // ════════════════════════════════════════════
    match /users/{userId} {

      // Anyone can read their OWN profile
      // Admins & teachers can read profiles in their school
      // Parents can read their children's profiles
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (isAnyRole(['admin', 'teacher']) && sameSchool(resource.data.schoolId))
        || isParentOf(userId)
      );

      // Users can update their own non-role fields
      // Admins can update any user in their school
      allow update: if isSignedIn() && (
        (request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'schoolId']))
        || (isRole('admin') && sameSchool(resource.data.schoolId))
      );

      // Only admins can create users in their own school
      allow create: if isRole('admin')
        && request.resource.data.schoolId == userDoc().schoolId;

      // Only admins can delete users in their school
      allow delete: if isRole('admin')
        && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /schools/{schoolId}
    // ════════════════════════════════════════════
    match /schools/{schoolId} {

      // Any authenticated member of the school can read
      allow read: if sameSchool(schoolId);

      // Only admins of that school can write
      allow write: if isRole('admin') && sameSchool(schoolId);
    }

    // ════════════════════════════════════════════
    //  /assignments/{assignmentId}
    // ════════════════════════════════════════════
    match /assignments/{assignmentId} {

      // Teachers, students, and admins in the same school can read
      allow read: if isAnyRole(['admin', 'teacher', 'student'])
        && sameSchool(resource.data.schoolId);

      // Parents can read assignments linked to their child's school
      allow read: if isRole('parent')
        && sameSchool(resource.data.schoolId);

      // Only admins and teachers in the same school can create/update
      allow create: if isAnyRole(['admin', 'teacher'])
        && request.resource.data.schoolId == userDoc().schoolId;

      allow update: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId)
        // schoolId cannot be changed after creation
        && request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if isRole('admin')
        && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /marks/{markId}
    //  KEY RULE: Parents can ONLY see their own
    //  child's marks. Teachers see only their school.
    // ════════════════════════════════════════════
    match /marks/{markId} {

      // Admins & teachers → must be in the same school
      allow read: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId);

      // Students → can only read their own marks
      allow read: if isRole('student')
        && resource.data.studentId == request.auth.uid;

      // Parents → can ONLY read marks for their child(ren)
      allow read: if isParentOf(resource.data.studentId);

      // Teachers & admins in the same school can create/update marks
      allow create: if isAnyRole(['admin', 'teacher'])
        && request.resource.data.schoolId == userDoc().schoolId;

      allow update: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId)
        && request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if isRole('admin')
        && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /submissions/{submissionId}
    //  Students create. Teachers in same school
    //  can read & grade. Students see only their own.
    // ════════════════════════════════════════════
    match /submissions/{submissionId} {

      // Students can read their own submissions
      allow read: if isRole('student')
        && resource.data.studentId == request.auth.uid;

      // Teachers & admins in the same school can read all submissions
      allow read: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId);

      // Students can create a submission (for their own ID, their school)
      allow create: if isRole('student')
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.schoolId == userDoc().schoolId;

      // Teachers/admins can update (grade) submissions in their school
      allow update: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId)
        // Only score, gradedBy, gradedAt may change
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['score', 'gradedBy', 'gradedAt']);

      allow delete: if isRole('admin')
        && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /schools/{schoolId}/terms/{termId}
    //  /schools/{schoolId}/classes/{classId}
    //  /schools/{schoolId}/subjects/{subjectId}
    //  /schools/{schoolId}/subjects/{subjectId}/topics/{topicId}
    // ════════════════════════════════════════════
    match /schools/{schoolId}/terms/{termId} {
      allow read: if isSignedIn() && sameSchool(schoolId);
      allow write: if isRole('admin') && sameSchool(schoolId);
    }

    match /schools/{schoolId}/classes/{classId} {
      allow read: if isSignedIn() && sameSchool(schoolId);
      allow write: if isAnyRole(['admin', 'teacher']) && sameSchool(schoolId);
    }

    match /schools/{schoolId}/subjects/{subjectId} {
      allow read: if isSignedIn() && sameSchool(schoolId);
      allow write: if isAnyRole(['admin', 'teacher']) && sameSchool(schoolId);
    }

    match /schools/{schoolId}/subjects/{subjectId}/topics/{topicId} {
      allow read: if isSignedIn() && sameSchool(schoolId);
      allow write: if isAnyRole(['admin', 'teacher']) && sameSchool(schoolId);
    }

    // ════════════════════════════════════════════
    //  /videoLessons/{lessonId}
    // ════════════════════════════════════════════
    match /videoLessons/{lessonId} {
      allow read: if isSignedIn() && sameSchool(resource.data.schoolId);
      allow create: if isAnyRole(['admin', 'teacher'])
        && request.resource.data.schoolId == userDoc().schoolId;
      allow update: if isAnyRole(['admin', 'teacher']) && sameSchool(resource.data.schoolId);
      allow delete: if isRole('admin') && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /videoComments/{commentId}
    // ════════════════════════════════════════════
    match /videoComments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isRole('admin')
        || request.auth.uid == resource.data.userId;
    }

    // ════════════════════════════════════════════
    //  /conversations/{conversationId}
    // ════════════════════════════════════════════
    match /conversations/{conversationId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;
    }

    // ════════════════════════════════════════════
    //  /conversations/{conversationId}/messages/{messageId}
    // ════════════════════════════════════════════
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // ════════════════════════════════════════════
    //  /notifications/{notificationId}
    // ════════════════════════════════════════════
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;
    }

    // ════════════════════════════════════════════
    //  /projects/{projectId}
    // ════════════════════════════════════════════
    match /projects/{projectId} {
      allow read: if isSignedIn() && sameSchool(resource.data.schoolId);
      allow create: if isAnyRole(['admin', 'teacher'])
        && request.resource.data.schoolId == userDoc().schoolId;
      allow update: if isSignedIn() && sameSchool(resource.data.schoolId);
      allow delete: if isRole('admin') && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /projects/{projectId}/files/{fileId}
    // ════════════════════════════════════════════
    match /projects/{projectId}/files/{fileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ════════════════════════════════════════════
    //  /timetable/{entryId}
    // ════════════════════════════════════════════
    match /timetable/{entryId} {
      allow read: if isSignedIn() && sameSchool(resource.data.schoolId);
      allow create: if isAnyRole(['admin', 'teacher'])
        && request.resource.data.schoolId == userDoc().schoolId;
      allow update: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId);
      allow delete: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /announcements/{announcementId}
    // ════════════════════════════════════════════
    match /announcements/{announcementId} {
      allow read: if isSignedIn() && sameSchool(resource.data.schoolId);
      allow create: if isAnyRole(['admin', 'teacher'])
        && request.resource.data.schoolId == userDoc().schoolId;
      allow update: if isAnyRole(['admin', 'teacher'])
        && sameSchool(resource.data.schoolId);
      allow delete: if isRole('admin')
        && sameSchool(resource.data.schoolId);
    }

    // ════════════════════════════════════════════
    //  /fees/{feeId}
    // ════════════════════════════════════════════
    match /fees/{feeId} {
      // Admins see all fees in their school
      allow read: if isRole('admin') && sameSchool(resource.data.schoolId);
      // Teachers can read fees in their school
      allow read: if isRole('teacher') && sameSchool(resource.data.schoolId);
      // Students see only their own fees
      allow read: if isRole('student') && resource.data.studentId == request.auth.uid;
      // Parents see their child's fees
      allow read: if isParentOf(resource.data.studentId);

      allow create: if isRole('admin')
        && request.resource.data.schoolId == userDoc().schoolId;
      allow update: if isRole('admin') && sameSchool(resource.data.schoolId);
      allow delete: if isRole('admin') && sameSchool(resource.data.schoolId);

      // Payment sub-collection
      match /payments/{paymentId} {
        allow read: if isSignedIn();
        allow create: if isRole('admin');
        allow delete: if isRole('admin');
      }
    }

    // ════════════════════════════════════════════
    //  Deny everything else by default
    // ════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
